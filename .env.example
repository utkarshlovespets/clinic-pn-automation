# Google Sheets
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_FILE=secrets/credentials.json
GOOGLE_TOKEN_FILE=secrets/token.json

# Render web app and cron support
ADMIN_API_KEY=
APP_BASE_URL=
ENABLE_LIVE_RUNS=false
CRON_LIVE=false
CRON_MAX_WORKERS=10

# If you want the app to materialize Google credentials from env vars on Render,
# paste base64-encoded JSON values below. Otherwise upload them as files and keep the
# *_FILE paths above.
GOOGLE_CREDENTIALS_B64=
GOOGLE_TOKEN_B64=

# CleverTap
CLEVERTAP_ACCOUNT_ID=
CLEVERTAP_PASSCODE=
CLEVERTAP_REGION=in1
CLEVERTAP_CAMPAIGN_ID=

# MySQL (Stage 0 only)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
